<% if(success && success.length) { %>
    <div class="alert alert-success alert-dismissible fade show col-12 col-sm-10 col-md-8 col-lg-6 mx-auto" role="alert" id="flashSuccess">
        <i class="fa-solid fa-circle-check me-2"></i><%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<% if(error && error.length) { %>
    <div class="alert alert-danger alert-dismissible fade show col-12 col-sm-10 col-md-8 col-lg-6 mx-auto" role="alert" id="flashError">
        <i class="fa-solid fa-circle-exclamation me-2"></i><%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>